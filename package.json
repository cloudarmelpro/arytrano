{
  "name": "arytrano",
  "version": "0.1.0",
  "private": true,
  "description": "AryTrano monorepo — student housing platform for Madagascar. apps/web (Next.js) + apps/mobile (Expo) sharing packages/shared (Zod + types).",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @arytrano/web",
    "build": "npm run build -w @arytrano/web",
    "start": "npm run start -w @arytrano/web",
    "lint": "npm run lint -w @arytrano/web",
    "test": "npm run test -w @arytrano/web",
    "test:watch": "npm run test:watch -w @arytrano/web",
    "test:coverage": "npm run test:coverage -w @arytrano/web",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "prisma:generate": "npm run prisma:generate -w @arytrano/web",
    "prisma:migrate": "npm run prisma:migrate -w @arytrano/web",
    "prisma:seed": "npm run prisma:seed -w @arytrano/web",
    "prisma:studio": "npm run prisma:studio -w @arytrano/web",
    "shared:typecheck": "npm run typecheck -w @arytrano/shared"
  }
}
