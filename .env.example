# ============================================================
# AryTrano — Local dev env template
# Copy to .env and fill values. .env is gitignored.
# ============================================================

# --- Database (matches docker-compose.yml) -------------------
DATABASE_URL="postgresql://arytrano:arytrano_dev@localhost:5432/arytrano?schema=public"

# --- Auth.js (web sessions) + JWT (mobile) -------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# --- Google OAuth (optional, enables Sign in with Google) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 client ID
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Facebook OAuth (optional, enables Sign in with Facebook)
# developers.facebook.com → My Apps → Create App → Facebook Login
# Redirect URI: <AUTH_URL>/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# --- Email via Gmail SMTP ------------------------------------
# Requires 2FA + App Password from https://myaccount.google.com/apppasswords
# Free tier ~100 emails/day. For prod, swap to Resend / SES / Postmark.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
EMAIL_FROM="AryTrano <user@example.com>"

# --- Cloudinary (image hosting) ------------------------------
# Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Upload preset created in Cloudinary settings → Upload presets (unsigned mode)
CLOUDINARY_UPLOAD_PRESET=""

# --- GoalPay (v2 — payments) ---------------------------------
GOALPAY_API_TOKEN_DEV=""
GOALPAY_WEBHOOK_SECRET=""
GOALPAY_BASE_URL="https://donation.goalpay.pro"

# --- Encryption (OwnerProfile.cinCiphertext, v0.5) -----------
# 32 bytes, base64. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PII_ENCRYPTION_KEY=""

# --- Upstash Redis (rate limiting) ---------------------------
# Create a free database at https://console.upstash.com/redis
# When both are set, rate limiters enforce: login 10/5min/IP, forgot-password
# 3/h/email + 10/h/IP, register 5/h/IP. When missing, fail-open with warning.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
