  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// PAYMENTS — v2 (stub, GoalPay)
// PaymentEvent is an immutable audit trail: INSERT only.
// ============================================================

// `idempotencyKey` is the merchant-side reference we generate (cuid)
// and pass to GoalPay as their `reference` field. GoalPay echoes it
// back in webhook payloads (`data.reference`), so we use it as the
// idempotency anchor for webhook lookups.
//
// `providerTxId` stores GoalPay's `order_reference` (returned by the
// init endpoint and echoed in webhooks as `data.order_reference`).
// Nullable until the init response is recorded.
//
// `amountMGA` is `Int` per memory `project_mga_no_subunit` — Ariary
// has no subunit, `iraimbilanja` is defunct. GoalPay's API works in
// integer Ariary too.
model Payment {
  id                String              @id @default(cuid())
  userId            String
  listingId         String?
  idempotencyKey    String              @unique
  provider          PaymentProviderName
  providerTxId      String?             @unique
  amountMGA         Int
  purpose           PaymentPurpose
  status            PaymentStatus       @default(INITIATED)
  payerPhone        String? // E.164
  createdAt         DateTime            @default(now())
  // Expiry of the GoalPay checkout link (createdAt + 10 min, per docs).
  // Used by the E-T20 reconciliation cron to mark stuck INITIATED rows.
  expiresAt         DateTime?
  // Set on the first webhook arrival, regardless of status. Audit trail.
  webhookReceivedAt DateTime?
  // Set when status transitions to CONFIRMED (a successful payment).
  completedAt       DateTime?
  // PAY-09 — finalisation of the manual refund flow. GoalPay has no
  // refund API, so an admin pushes REFUND_PENDING → REFUNDED after
  // confirming the off-platform transfer (proof / providerTxId of the
  // refund leg pasted into refundNote).
  refundedAt        DateTime?
  refundedById      String?
  refundedBy        User?               @relation("PaymentRefundedBy", fields: [refundedById], references: [id], onDelete: SetNull)
  refundNote        String?

  user    User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  listing Listing?       @relation(fields: [listingId], references: [id], onDelete: SetNull)
  events  PaymentEvent[]
  lease   Lease?

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt])
}

enum PaymentProviderName {
  GOALPAY
}

enum PaymentPurpose {
  PREMIUM_LISTING // legacy (superseded by LEASE_SUCCESS_FEE in v2 model)
  FEATURED_PLACEMENT // legacy (superseded)
  LEASE_SUCCESS_FEE // E-T26 — 15k Ar + 8% caution per signed lease
  // future: DEPOSIT, FIRST_MONTH (à valider légalement — E-T18 frozen)
}

enum PaymentStatus {
  INITIATED // POST to GoalPay sent, checkout_url returned, awaiting user
  PENDING // Reserved for future async states (not used by GoalPay v1)
  CONFIRMED // Webhook payment.success received + verified
  FAILED // Webhook payment.failed received
  CANCELED // Webhook payment.canceled received (user abandoned)
  EXPIRED // Webhook payment.expired received (10 min checkout TTL)
  REFUND_PENDING // Admin opened a manual refund (GoalPay has no refund API)
  REFUNDED // Manual refund confirmed via GoalPay support
}

model PaymentEvent {
  id         String        @id @default(cuid())
  paymentId  String
  status     PaymentStatus
  rawPayload Json // raw provider response (kept for disputes)
  /// PAY-14 — sha256 over the canonical event tuple (reference + event
  /// type + orderReference + amountMGA). Unique so a GoalPay retry
  /// storm of the SAME event collapses to one row instead of bloating
  /// the audit trail. Nullable so legacy rows (pre-PAY-14) stay valid.
  dedupKey   String?       @unique
  occurredAt DateTime      @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, occurredAt])
}

// ============================================================
// LEASES — E-T26 (revised 2026-05-27, tenant-pays model)
//
// A Lease materializes the agreement between an owner and a tenant
// for a specific listing. The AryTrano success fee (20% of monthly
// rent, snapshotted on `platformFeeMGA`) is paid by the TENANT at
// lease acceptance, not by the owner. Rent + caution flow OFFLINE
// between tenant and owner.
//
// State machine :
//   DRAFT             — vestigial in the new model; kept for backward
//                       compat with historical rows
//   PENDING_TENANT    — owner created the lease; tenant must accept + pay
//                       the platform fee via GoalPay
//   ACTIVE            — tenant accepted + paid; Listing.status → RENTED
//   REFUSED           — tenant refused OR owner canceled before tenant paid
//                       (manual refund queued on Payment.REFUND_PENDING
//                       only if the tenant had already paid)
//   TERMINATED        — lease ended naturally at the end of its term
//   DISPUTED          — open dispute (E-T27 arbitrage)
// ============================================================

model Lease {
  id                     String      @id @default(cuid())
  listingId              String
  ownerId                String
  tenantId               String
  monthlyRentMGA         Int
  cautionMGA             Int         @default(0)
  startDate              DateTime
  durationMonths         Int
  // E-T26 (revised 2026-05-27) — platform fee charged to the TENANT
  // at lease acceptance, NOT the owner. Default rate is 20% of the
  // monthly rent (= PLATFORM_FEE_RATE × monthlyRentMGA, floored).
  // Snapshotted on the row so a future rate change leaves audit trails
  // intact. Owner pays nothing to AryTrano — the rent + caution flow
  // directly between tenant and owner offline.
  platformFeeMGA         Int         @default(0)
  paymentId              String?     @unique
  status                 LeaseStatus @default(PENDING_TENANT)
  // ownerSignedAt now set at lease CREATION (owner commit = create
  // the lease wizard; no payment step on owner side). tenantSignedAt
  // set when the tenant pays + transition to ACTIVE.
  ownerSignedAt          DateTime?
  tenantSignedAt         DateTime?
  terminatedAt           DateTime?
  // E-T27.1 (2026-06-12) — auto-generated lease PDF.
  // Trigger : Lease.status flips PENDING_TENANT → ACTIVE.
  // Storage : Cloudinary `raw` resource in the private
  // `arytrano/leases/` folder. Downloaded via signed URL with 7-day
  // TTL — the dashboard re-signs on every render so paste-the-link
  // sharing expires fast.
  contractPdfUrl         String?
  contractPdfPublicId    String?
  contractPdfGeneratedAt DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  listing        Listing         @relation(fields: [listingId], references: [id], onDelete: Restrict)
  owner          User            @relation("OwnerLeases", fields: [ownerId], references: [id], onDelete: Restrict)
  tenant         User            @relation("TenantLeases", fields: [tenantId], references: [id], onDelete: Restrict)
  payment        Payment?        @relation(fields: [paymentId], references: [id])
  // E-T28 — when a lead converts via an operator deep-link, the resulting
  // Lease has a back-pointer to the originating LeadRequest. Unique side
  // is on LeadRequest.leaseId — one lead converts to at most one lease.
  leadRequest    LeadRequest?    @relation("LeadConvertedLease")
  // E-T27.2 — état des lieux ENTRY + EXIT.
  inventoryItems InventoryItem[]
  // E-T27.3 — caution arbitrage. At most one ACTIVE dispute per lease
  // is enforced by a partial UNIQUE INDEX (migration
  // 20260612120000) WHERE status IN ('OPEN', 'IN_REVIEW') ;
  // historical resolved disputes can coexist with a new one.
  disputes       Dispute[]

  @@index([listingId])
  @@index([ownerId, status])
  @@index([tenantId, status])
  @@index([status, createdAt])
}

// E-T27.3 — Arbitrage caution (2026-06-12)
//
// When a Lease in TERMINATED has an unresolved disagreement about
// the caution (typically : owner withholds part of the deposit
// citing damages ; tenant disputes), either party can OPEN a
// Dispute. The lease transitions to DISPUTED. An admin compares
// the ENTRY and EXIT InventoryItems side by side, reads the
// claims and counter-claims, and renders a verdict (resolved
// for owner / tenant / split) under a 7-day SLA target.
//
// AryTrano does NOT escrow the caution — it's released directly
// between the parties offline. The arbitrage verdict is a
// non-binding mediation (the runbook + CGU sections state this).
// The verdict drives reputation impact : a verdict against an
// owner counts toward losing the "Propriétaire vérifié" badge
// after N repeated rulings.
//
// Claim / resolve are now SEPARATED (audit fix 2026-06-12):
// `claimedById/claimedAt` mark the admin who took ownership of the
// triage during IN_REVIEW. `resolvedById/resolvedAt` are written
// ONLY when the verdict is rendered. Reading the audit trail later
// distinguishes "who handled" from "who decided".
model Dispute {
  id                 String        @id @default(cuid())
  leaseId            String
  // Who opened it. Either party can ; we also track in the activity
  // log who said what.
  openedById         String
  // OWNER / TENANT — the role the opener was playing when they
  // raised it. Lets us render the correct prompt copy without a
  // join into Lease.
  openedByRole       DisputeParty
  status             DisputeStatus @default(OPEN)
  // First message — typically the reason + amount the owner is
  // withholding. Stored separately from `claims` because it's the
  // anchor of the conversation.
  initialClaim       String
  // Total amount the parties disagree on (typically owner-withheld
  // share of the caution). Helps the admin prioritize.
  amountAtStakeMGA   Int
  // Snapshot of the Lease.status at the moment the dispute was
  // opened (typically ACTIVE or TERMINATED). When the dispute is
  // resolved we restore the lease to THIS status, not always
  // TERMINATED — otherwise opening a frivolous dispute on an
  // ACTIVE lease would let one party unilaterally end the bail.
  leaseStatusAtOpen  LeaseStatus
  // SLA target = openedAt + 7 days. Admin nudge cron warns when
  // close to the deadline (E-T27.3 follow-up).
  slaDueAt           DateTime
  // Admin who claimed the dispute (took it into IN_REVIEW). Set
  // when status flips OPEN -> IN_REVIEW. A second admin who tries
  // to steal the claim is REJECTED — only the original claimer or
  // a fresh re-claim after a release is allowed.
  claimedById        String?
  claimedAt          DateTime?
  resolvedAt         DateTime?
  // Final ruling — set when status flips to RESOLVED_*. Free-text
  // for now ; could become structured per the E-T27 runbook.
  verdict            String?
  // Admin who rendered the verdict. SetNull on admin delete so the
  // dispute row survives an account purge. NULL until resolve.
  resolvedById       String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  lease      Lease            @relation(fields: [leaseId], references: [id], onDelete: Restrict)
  openedBy   User             @relation("DisputesOpened", fields: [openedById], references: [id], onDelete: Restrict)
  claimedBy  User?            @relation("DisputesClaimed", fields: [claimedById], references: [id], onDelete: SetNull)
  resolvedBy User?            @relation("DisputesResolved", fields: [resolvedById], references: [id], onDelete: SetNull)
  messages   DisputeMessage[]

  // Hot scan : `WHERE status IN (OPEN, IN_REVIEW) ORDER BY slaDueAt`.
  @@index([status, slaDueAt])
  @@index([leaseId])
  // FK coverage for "my assigned" / "my resolved" admin lookups.
  @@index([claimedById])
  @@index([resolvedById])
  // FK coverage for openedById (audit trail by user).
  @@index([openedById])
}

enum DisputeParty {
  OWNER
  TENANT
}

enum DisputeStatus {
  OPEN // freshly opened, waiting for admin triage
  IN_REVIEW // admin claimed it, gathering both sides
  RESOLVED_OWNER // verdict : owner's position wins (or partially)
  RESOLVED_TENANT // verdict : tenant's position wins (or partially)
  RESOLVED_SPLIT // both sides have a partial valid claim
  WITHDRAWN // opening party withdrew before resolution
}

// Append-only conversation log for a dispute. Both parties + the
// admin write to it. The admin's verdict ALSO writes a final message
// flagged isVerdict.
model DisputeMessage {
  id          String       @id @default(cuid())
  disputeId   String
  authorId    String
  authorRole  DisputeParty // who's speaking — used for visual styling
  body        String
  // Set true when this message IS the admin verdict (single row per
  // dispute, enforced application-side).
  isVerdict   Boolean      @default(false)
  // Optional attachments — Cloudinary URLs. Same allowed list as
  // inventory photos.
  attachments String[]     @default([])
  createdAt   DateTime     @default(now())

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  author  User    @relation("DisputeMessages", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([disputeId, createdAt])
  // FK coverage — "messages I authored" + cheaper RESTRICT check on
  // User delete. Audit fix 2026-06-12.
  @@index([authorId])
}

// E-T27.2 — état des lieux numérique (2026-06-12)
//
// One InventoryItem per (lease, phase, room) — owner and tenant
// co-upload photos at lease ACTIVE (ENTRY phase) and at TERMINATED
// (EXIT phase). The arbitrage path (E-T27.3) compares ENTRY vs
// EXIT side-by-side when a dispute opens.
//
// roomKey is a STRING (not an enum) so owners can add custom rooms
// without a migration ("Chambre des parents", "Garage", etc.).
// We seed the UI with a canonical list (SALON, CUISINE, CHAMBRE_1,
// CHAMBRE_2, SALLE_DE_BAIN, WC, BALCON, ENTREE, AUTRE) and let the
// visitor free-text beyond that.
//
// photoUrls : array of Cloudinary secure_urls. Same upload pipeline
// as listing photos (EXIF strip, 5MB cap, JPG/PNG/WebP/HEIC).
// Each photo lives in `arytrano/leases/<leaseId>/inventory/<phase>/`
// so a Cloudinary admin sees the lease structure at a glance.
//
// @@unique([leaseId, phase, roomKey]) — one row per room per phase.
// Updating photos = updating the row. The cron at lease termination
// nudges both parties to upload but never auto-creates rows.
model InventoryItem {
  id           String         @id @default(cuid())
  leaseId      String
  phase        InventoryPhase
  // String, not enum — owners add custom labels.
  roomKey      String
  // Free-text observations (taches, défauts, équipements présents).
  // Bounded server-side at 2000 chars to keep the dispute UI legible.
  notes        String?
  // Cloudinary secure_urls. Postgres text[] for predictable queries.
  // Bounded at 20 per room (DB-side check enforced via service).
  photoUrls    String[]       @default([])
  uploadedById String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  lease      Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@unique([leaseId, phase, roomKey])
  // FK coverage — "items I uploaded" + cheaper RESTRICT check on
  // User delete. Audit fix 2026-06-12.
  @@index([uploadedById])
}

enum InventoryPhase {
  ENTRY // taken at Lease ACTIVE — before key handover
  EXIT // taken at Lease TERMINATED — triggers caution release
}

enum LeaseStatus {
  // DRAFT is vestigial in the new tenant-pays model — owner creates
  // a lease directly into PENDING_TENANT. Kept in the enum for
  // backward compatibility with historical rows and future flows
  // (admin tooling that might park a lease in DRAFT pre-tenant invite).
  DRAFT
  PENDING_TENANT // owner created the lease; tenant must accept + pay
  ACTIVE // tenant accepted, paid the platform fee, lease live
  REFUSED // tenant refused OR owner canceled before tenant paid
  TERMINATED // lease ended (at end of durationMonths)
  DISPUTED // E-T27 arbitrage open
}

// ============================================================
// E-T28 · Concierge lead queue (2026-06-10)
// ============================================================

/**
 * A signed-out OR signed-in student declares interest in a listing
 * via the public detail-page CTA ("Je suis intéressé(e)" / "Liana
 * aho"). The AryTrano operator desk claims the lead, negotiates with
 * the owner on WhatsApp (off-platform), and converts the lead to a
 * Lease via the LeaseWizard with a signed `operatorActingForOwnerId`
 * deep-link.
 * Design choices (workflow synthesis 2026-06-10) :
 * - Concurrent leads ALLOWED per listing — no partial unique on
 * listingId. The operator arbitrates which one converts; losers
 * transition to REJECTED with a NOTE LeadActivity.
 * - Anonymous submission allowed via phone OTP — `tenantUserId` is
 * nullable. When the lead later signs up, an operator can attach
 * the User via `transitionLeadStatus`. `tenantPhone` is stored
 * in clear (E.164) for operator contact; `tenantPhoneHash` is the
 * pepper-keyed SHA-256 used in rate-limit keys + log scrubbing.
 * - `claimedByUserId` is server-enforced to a maximum WIP of 6 per
 * operator (T-RES-06). Race-safe via a SERIALIZABLE transaction.
 * - `slaDueAt` is set on claim (= now + 4h). The
 * `sweep-stale-claimed` cron auto-reverts to NEW + reassigns past
 * that deadline (T-RES-10).
 * - `leaseId` is nullable + `@unique` — one lead converts to at most
 * one lease. The back-pointer lives on Lease via `leadRequest`.
 * - All state transitions are mirrored to `LeadActivity` rows so the
 * operator dashboard shows a full history + dispute evidence.
 */
model LeadRequest {
  id               String       @id @default(cuid())
  listingId        String
  // Nullable — anonymous tenant via phone OTP. Once linked
  // (tenant signs up later), the operator runs `attachLeadToUser`.
  tenantUserId     String?
  // Display name shown to the operator in the queue. Not validated
  // against an account because anonymous leads exist.
  tenantName       String
  // E.164 normalized, e.g. `+261341234567`. Stored in clear for the
  // operator to dial — protected by ADMIN role-gate on every read.
  tenantPhone      String
  // SHA-256(phone + pepper). Used in rate-limit keys (per memory
  // `feedback_rate_limit_null_ip` fail-CLOSED pattern) and in
  // Sentry/log payloads (per memory `feedback_debug_logs_no_pii`).
  tenantPhoneHash  String
  // OTP-only flows always set `email = NULL`. When the tenant later
  // links a User, we keep `email` derived from the User (not stored
  // here) — admins read it via the relation.
  moveInWindow     MoveInWindow
  // Tenant ticks "j'ai le budget pour ce loyer" before submission —
  // false = tenant skipped the check, raised lead. Operator uses
  // this signal during qualification.
  budgetConfirmed  Boolean      @default(false)
  status           LeadStatus   @default(NEW)
  source           LeadSource   @default(WEB)
  claimedByUserId  String?
  claimedAt        DateTime?
  // Computed = claimedAt + 4h. `sweep-stale-claimed` cron scans
  // `WHERE status = CLAIMED AND slaDueAt < now()` — index
  // `[status, slaDueAt]` makes that O(log n).
  slaDueAt         DateTime?
  // Set the first time the operator logs a MESSAGED activity. Used
  // to compute "first response latency" metric for analytics.
  firstContactedAt DateTime?
  // Back-pointer to the converted Lease. `@unique` so a single lead
  // can't be linked to two Lease rows. `leadRequest` relation on
  // Lease completes the round-trip.
  leaseId          String?      @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  listing    Listing        @relation(fields: [listingId], references: [id], onDelete: Restrict)
  tenant     User?          @relation("LeadTenant", fields: [tenantUserId], references: [id], onDelete: SetNull)
  claimedBy  User?          @relation("LeadClaimedBy", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  lease      Lease?         @relation("LeadConvertedLease", fields: [leaseId], references: [id], onDelete: SetNull)
  activities LeadActivity[]

  // Cron scan: sweep-unclaimed (status=NEW) + sweep-stale-claimed
  // (status=CLAIMED + slaDueAt) all hit this single composite index.
  @@index([status, slaDueAt])
  // Per-listing operator view (admin filters by listing + status).
  @@index([listingId, status])
  // Operator dashboard "leads I'm currently working" filter.
  @@index([claimedByUserId, status])
  // Anti-duplicate-spam : a tenant phone soumitting twice on the
  // same listing within a short window is filtered in-service
  // (service-side check, not a DB unique because the second lead
  // 25h later is legitimate). Index keeps the lookup O(log n).
  @@index([tenantPhoneHash, listingId, createdAt])
}

/**
 * Append-only activity log on a LeadRequest. Every status transition,
 * every operator note, every system event (cron escalation,
 * auto-revert) writes a row here. The operator dashboard renders
 * the timeline; the disputes path uses it as evidence.
 * NEVER updated, only inserted — no `updatedAt`. The `payload` JSON
 * column holds type-specific data (e.g. for MESSAGED:
 * `{channel:'whatsapp', summary, direction:'outbound'}`).
 */
model LeadActivity {
  id          String           @id @default(cuid())
  leadId      String
  type        LeadActivityType
  // Nullable for SYSTEM-acted rows (cron jobs).
  actorUserId String?
  actorRole   LeadActorRole
  payload     Json
  createdAt   DateTime         @default(now())

  lead  LeadRequest @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor User?       @relation("LeadActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  // Timeline render on lead detail page (operator dashboard).
  @@index([leadId, createdAt])
  // Operator analytics — "how many MESSAGED activities did operator X
  // log this week ?" hits this index.
  @@index([actorUserId, type, createdAt])
}

/**
 * Operator shift declarations. An ADMIN operator marks themselves as
 * "on shift" so the `createInterestLead` push-fan-out (T-RES-09)
 * only notifies operators who can actually answer. Shifts are
 * non-overlapping per-operator (enforced service-side).
 */
model OperatorShift {
  id         String   @id @default(cuid())
  operatorId String
  startsAt   DateTime
  endsAt     DateTime
  createdAt  DateTime @default(now())

  operator User @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  // Hot scan : `WHERE startsAt <= now() AND endsAt >= now()`.
  @@index([startsAt, endsAt])
  @@index([operatorId, startsAt])
}

enum LeadStatus {
  NEW // Just submitted, no operator claimed yet
  CLAIMED // An operator is working it; SLA running
  IN_DISCUSSION // Operator + owner + tenant exchanging
  AWAITING_OWNER // Operator waiting on owner reply
  AWAITING_TENANT // Operator waiting on tenant reply
  CONVERTED // Linked to a Lease via leaseId
  LAPSED // No activity > 14 days, auto-archived
  REJECTED // Tenant changed mind, owner off-platform, etc.
}

enum LeadSource {
  WEB // Public detail page CTA
  MOBILE // Mobile app (Expo) — REST POST /api/v1/leads
  REST // Third-party / partner integration
}

enum LeadActivityType {
  CREATED // LeadRequest created (system, on insert)
  CLAIMED // Operator claimed the lead
  MESSAGED // Operator logged a WhatsApp / phone message
  NO_RESPONSE_WARN // Cron flagged the lead near its SLA
  CONVERTED // Operator converted to Lease via deep-link
  LAPSED // Cron archived after 14d inactivity
  REASSIGNED // Cron auto-reverted from CLAIMED → NEW
  REJECTED // Operator marked rejected (with reason)
  NOTE // Free-form operator note
}

enum LeadActorRole {
  TENANT // The student
  OWNER // The listing owner
  OPERATOR // AryTrano admin
  SYSTEM // Cron job, no human actor
}

enum MoveInWindow {
  THIS_MONTH
  NEXT_MONTH
  IN_2_MONTHS
  FLEXIBLE
}

// Editorial testimonials shown on marketing surfaces (landing owner
// block, future student page, etc.). Hand-curated by admin — owners
// don't write these themselves; we collect quotes after a successful
// rental and copy them in. Separating audience lets us show owner
// quotes to owner-facing visitors and student quotes to student-facing
// visitors without a runtime filter mismatch.
model Testimonial {
  id          String              @id @default(cuid())
  audience    TestimonialAudience
  body        String              @db.Text
  authorName  String
  // Optional secondary line under the name, e.g. "3 logements vérifiés
  // · Andrainjato" or "Étudiante en L3 · Tsianolondroa". Free-form so
  // the editor can craft it per quote.
  authorMeta  String?
  // Hand-set ordering; lower first. Allows admin to pin a hero quote.
  sortOrder   Int                 @default(0)
  // When null, the testimonial is a draft. Only published rows are
  // served by the public queries — feature toggle for the admin.
  publishedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([audience, publishedAt, sortOrder])
}

enum TestimonialAudience {
  STUDENT
  OWNER
}

// Anonymous quiz submission. Captured on /quartiers/quiz when a
// student completes the 6-question wizard. Email is optional — the
// quiz shows results unconditionally; the email field exists for the
// "receive new listings in these quartiers" opt-in at the end.
//
// We store the raw answer payload + the slugs of the 3 quartiers we
// recommended so we can later audit reco quality ("did students who
// got Andrainjato actually click through?") and segment marketing
// ("students with budget < 200k who want a calm vibe").
//
// Indexed on createdAt so the admin dashboard can paginate recent
// submissions, and on email so we can dedupe / look up by user.
model QuizSubmission {
  id               String   @id @default(cuid())
  // ISO 639-1 + region of the submission ("fr-MG" or "mg"). Useful
  // when emailing back so the message language matches.
  // TODO(audit P2): migrate to `Locale` enum (FR_MG / MG) before the
  // table fills up — see prisma audit followup in TICKETS.
  locale           String
  // Null when the user skipped the optional email step.
  email            String?
  // 6 raw answer values as a JSON blob — keys match the quiz schema
  // (budget, school, housingType, vibe, mobility, priority). We
  // intentionally store these flat rather than as separate columns so
  // adding/removing a question is a code-only change, no migration.
  answers          Json
  // Slugs of the 3 quartiers we recommended, ranked best → worst.
  // Stored at submission time so reco audit isn't affected by later
  // changes to the scoring algorithm.
  recommendedSlugs String[]
  // IP hash for rate-limiting + abuse pattern detection. We never
  // store the raw IP. Null when proxy could not derive one.
  ipHash           String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

// Anonymous WhatsApp alert subscription. Captured from the footer
// newsletter block — visitors leave a phone number to be notified by
// WhatsApp when new listings publish.
//
// v1: just stores the number. Outbound notifications are still manual
// (admin broadcasts) — we don't want to wire WhatsApp Business API
// before we know there's enough demand to justify the cost.
//
// phoneE164 is UNIQUE so a re-submission of the same number is a
// no-op upsert (touches updatedAt), not a duplicate row. ipHash lets
// us spot abuse without storing PII.
model WhatsAppAlert {
  id               String    @id @default(cuid())
  // E.164 format ("+2613XXXXXXX"). Normalized server-side; never trust
  // the raw input from the form.
  phoneE164        String    @unique
  // Submission locale — drives the language of the future broadcast.
  // TODO(audit P2): migrate to `Locale` enum (FR_MG / MG) before the
  // table fills up — see prisma audit followup in TICKETS.
  locale           String
  // Optional neighborhood filter — students can subscribe to a specific
  // quartier. Null = "any new listing".
  quartierSlug     String?
  ipHash           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  // T-045 — public unsubscribe via one-click link.
  // `unsubscribeToken` is a long-lived crypto-random string included
  // in every outbound broadcast. When the user clicks the link,
  // `unsubscribedAt` flips to now() and broadcast queries filter the
  // row out. Token stays unique — once set, never reused — so a
  // re-subscribe of the same phone gets a fresh token.
  unsubscribedAt   DateTime?
  unsubscribeToken String?   @unique

  @@index([quartierSlug, createdAt])
  // Broadcast queries hit `WHERE unsubscribedAt IS NULL`; a partial
  // index on the live subset keeps the cron fast as the table grows.
  @@index([unsubscribedAt])
}

// ANA-09 — search query analytics. One row per non-trivial search on
// /annonces. `q` is a lowercased trimmed copy of the visitor's query;
// `resultCount` records how many listings matched at the time. Drives
// the "top zero-result queries" report so we know what content to seed.
model SearchQuery {
  id           String   @id @default(cuid())
  q            String
  resultCount  Int
  ipHash       String?
  createdAt    DateTime @default(now())

  @@index([q, createdAt])
  @@index([resultCount, createdAt])
  @@index([createdAt])
}

// OWN-12 — Web Push subscription. Each browser/device registration
// produces one row; the same user can have multiple. `endpoint` is
// unique so re-subscribing the same browser upserts cleanly.
model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint     String   @unique
  p256dh       String
  auth         String
  userAgent    String?
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  @@index([userId])
}

// TRU-11 — admin-managed blocklist for abusive IPs, phones, and emails.
// Consumed by requestPhoneOtp, createInterestLead, sign-in, sign-up.
enum BlocklistKind {
  IP_HASH
  PHONE
  EMAIL
}

model BlocklistEntry {
  id          String        @id @default(cuid())
  kind        BlocklistKind
  /// For IP_HASH stores the sha256 hex (same shape as ipHash on the
  /// rest of the codebase). For PHONE stores E.164. For EMAIL stores
  /// lowercase.
  value       String
  reason      String?
  createdById String?
  createdBy   User?         @relation("BlocklistCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  expiresAt   DateTime?
  createdAt   DateTime      @default(now())

  @@unique([kind, value])
  @@index([expiresAt])
}

// TRU-09 / ADM-05 — Admin audit log.
//
// One row per privileged admin action (verify/suspend listings, review
// CIN, resolve report/dispute, lead claim/transition/convert/link,
// operator shift toggle, video moderation, etc.). Read-only viewer at
// /admin/audit; rows are NEVER updated or deleted from the app — only
// the quarterly retention cron may prune > 12-month rows once shipped.
//
// `metadata` carries scope-specific context (oldStatus → newStatus,
// reason, ipHash). Keep it small (< 1KB) — no full bodies, no PII.
// `adminId` is nullable so a deleted admin user doesn't cascade and
// wipe the trail.
// ADM-08 — Free-form admin notes on users / listings.
//
// Generic by (targetType, targetId) so we can attach the same model to
// future entities (Lead, Lease, Dispute…) without a schema bump. Notes
// are visible only to admins; the author may edit/delete their own,
// other admins can view but not mutate.
// TEN-21 — explicit "this quartier is near this university" tags.
// Simpler + more accurate than the TEN-11 lat/lng bounding box because
// urban geography follows walking paths, not radial distance. The
// two co-exist: TEN-11 covers the automatic fallback, TEN-21 lets us
// promote specific quartiers when their reputation matters more than
// their raw distance (e.g. "Anjoma is IPT-central even if it's 3km").
model NeighborhoodUniversity {
  neighborhoodId String
  universityId   String
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)
  university     University   @relation(fields: [universityId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([neighborhoodId, universityId])
  @@index([universityId])
}

// TEN-11 — universities geocoded so search can filter "near IPNT".
// Lat/lng is the campus centroid (admin building). A listing is
// considered "near" when the haversine distance is below the search
// threshold (default 3km).
model University {
  id      String  @id @default(cuid())
  cityId  String
  city    City    @relation(fields: [cityId], references: [id], onDelete: Restrict)
  slug    String // "ipnt", "ua-fianarantsoa"
  /// Long form name shown in FR (default UI language).
  nameFr  String
  /// Short ticker shown on chips ("IPNT").
  acronym String
  lat     Decimal @db.Decimal(9, 6)
  lng     Decimal @db.Decimal(9, 6)
  /// Optional address line surfaced on hover / future university landing.
  address String?

  createdAt DateTime @default(now())

  neighborhoods NeighborhoodUniversity[]

  @@unique([slug])
  @@index([cityId])
}

model AdminNote {
  id         String   @id @default(cuid())
  authorId   String
  author     User     @relation("AdminNotesAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  /// Markdown-ish plain text; rendered as <pre>-wrapped on the panel.
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([targetType, targetId, createdAt])
  @@index([authorId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String?
  admin      User?    @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: SetNull)
  /// Short verb-style code, e.g. "listing.verify", "report.resolve",
  /// "lead.transition", "dispute.resolve". Use dotted lowercase so the
  /// viewer can group by domain.
  action     String
  /// What the action targets — "Listing", "User", "Report", "Lead",
  /// "Dispute", etc. Helps the viewer filter to one entity type.
  targetType String
  targetId   String
  metadata   Json?
  ipHash     String?
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
  @@index([createdAt])
}
