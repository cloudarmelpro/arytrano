// ============================================================
// AryTrano — Prisma schema
// Scope : v0 (live) + stubs v0.5 / v1 / v2 (not yet wired up).
// Conventions :
//   - cuid() for ids (collision-safe, non-enumerable)
//   - Decimal(12,2) for money (MGA / Ar)
//   - Decimal(9,6) for lat/lng
//   - Soft-delete via *Status enums, never DELETE rows
//   - Encrypted PII (CIN) : stored as Bytes (ciphertext + iv)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: connection URL lives in prisma.config.ts, not here.
datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH — Auth.js v5 Prisma adapter shape
// ============================================================

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  phone           String? // E.164, e.g. +261341234567
  // TRU-01 (2026-06-29) — owner SMS-verification gate. Set to the
  // verification timestamp when the User completes a successful OTP
  // round on this exact phone. The publishListing service refuses to
  // flip status to PUBLISHED unless this is non-null AND matches the
  // current `phone` (a phone edit clears it).
  phoneVerifiedAt DateTime?
  passwordHash    String? // credentials provider; null for OAuth-only users
  role          UserRole   @default(STUDENT)
  locale        Locale     @default(FR_MG)
  status        UserStatus @default(ACTIVE)
  // Incremented on password change/reset and OAuth unlink so existing JWT
  // mobile tokens (still valid until expiry) are invalidated immediately.
  tokenVersion  Int        @default(0)

  // TOTP 2FA — encrypted shared secret + activation timestamp. When
  // `totpEnabledAt` is non-null, the credentials sign-in flow demands a
  // step-2 6-digit code (or a one-time recovery code).
  totpSecret    String?
  totpEnabledAt DateTime?

  // Owner CGU acceptance (T-049, 2026-05-29) — set when an OWNER
  // account accepts the dedicated Owner Terms via /onboarding/owner/terms.
  // Null for STUDENTs (they accept the generic /legal/terms inline at
  // sign-up). Used by the dashboard layout gate to block owner activity
  // (publishing, lease creation) until acceptance.
  // `version` lets us re-prompt on future legally meaningful changes
  // without resetting the timestamp.
  ownerTermsAcceptedAt DateTime?
  ownerTermsVersion    String?

  // T-047 — owners get an email on every contact click by default.
  // Toggle off via /dashboard/settings if they prefer to check the
  // dashboard only. Students never trigger this (they don't own
  // listings) — the field exists on User to keep the toggle UI in
  // one place.
  contactNotificationsEnabled Boolean @default(true)

  // COM-08 — granular email preferences. All default to true so
  // existing users keep their current behaviour; the
  // /dashboard/notifications page lets them opt out per category.
  // Each flag is consulted by the sender at fan-out time.
  savedSearchAlertsEnabled       Boolean @default(true)
  listingExpirationAlertsEnabled Boolean @default(true)
  leaseUpdatesEnabled            Boolean @default(true)

  // TRU-19 — self-service account deletion with a 30-day grace window.
  // When the user requests deletion we set this timestamp; a cron
  // finalises the row past this date. Users can cancel until then.
  deletionScheduledAt DateTime?

  // ADM-03 — reason + timestamp when an admin flips status → SUSPENDED.
  // Read on sign-in to surface a friendly reason instead of a silent
  // "session expired". Cleared when status flips back to ACTIVE.
  suspendedReason  String?
  suspendedAt      DateTime?
  suspendedBy      String?

  // COM-12 — hard-bounce tracking. After EMAIL_BOUNCE_HARD_THRESHOLD
  // (default 3) hard bounces in a row, set emailDisabledAt to now.
  // Senders gate on emailDisabledAt and skip the send to protect the
  // domain's sender reputation. User can reactivate by updating their
  // email (which resets the counter — see update-profile).
  emailBouncesHard               Int       @default(0)
  emailDisabledAt                DateTime?

  // E-T07 — multi-city v1. Captured at sign-up or first listing
  // creation. Soft FK : SetNull on city delete so account survives
  // even if a city is later removed (admin tooling can't drop a
  // city with active listings; the cascade is here for migrations).
  preferredCityId String?
  preferredCity   City?   @relation(fields: [preferredCityId], references: [id], onDelete: SetNull)

  // E-T22 — Expo push notification token registered by the mobile app.
  // Shape : `ExponentPushToken[XXX]`. Sent to Expo's Push API server-
  // side when we want to notify the user (new listings in their saved
  // search, review prompts, etc.). `@unique` because two devices can't
  // share the same Expo token — if the same user signs into a new
  // device the old token gets overwritten on POST /api/v1/users/me/
  // push-token. Nullable since OAuth web users never have one.
  expoPushToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts            Account[]
  sessions            Session[]
  ownerProfile        OwnerProfile?
  listings            Listing[]
  reports             Report[]
  reviews             Review[]
  reviewReactions     ReviewReaction[]
  favorites           Favorite[]
  savedSearches       SavedSearch[]
  payments            Payment[]
  loginEvents         LoginEvent[]
  recoveryCodes       RecoveryCode[]
  contactEvents       ContactEvent[]
  pushReceipts        PushReceipt[]
  // E-T26 — leases the user owns (as landlord) and leases where they
  // are the tenant. Two separate relations via `@relation` name.
  ownerLeases         Lease[]          @relation("OwnerLeases")
  tenantLeases        Lease[]          @relation("TenantLeases")
  // E-T28 — concierge lead queue (2026-06-10).
  //  - `interestLeads`        : leads submitted while signed-in (anonymous
  //                              leads have tenantUserId NULL, so they
  //                              never appear here).
  //  - `claimedLeads`         : leads an ADMIN operator is currently
  //                              working. `claimedByUserId` FK.
  //  - `leadActivitiesActed`  : LeadActivity rows where this user was the
  //                              actor (operator note, tenant message,
  //                              etc.). SYSTEM-actor rows have actorUserId
  //                              NULL and never appear here.
  // Operator shift declarations (E-T28 T-RES-09 push-on-shift).
  interestLeads       LeadRequest[]    @relation("LeadTenant")
  claimedLeads        LeadRequest[]    @relation("LeadClaimedBy")
  leadActivitiesActed LeadActivity[]   @relation("LeadActivityActor")
  operatorShifts      OperatorShift[]
  // E-T27.2 — inventory uploads (ENTRY/EXIT) the user authored.
  inventoryItems      InventoryItem[]
  // E-T27.3 — disputes raised + claimed + resolved + messages.
  // claimed and resolved are now SEPARATE — see Dispute model for why.
  disputesOpened      Dispute[]        @relation("DisputesOpened")
  disputesClaimed     Dispute[]        @relation("DisputesClaimed")
  disputesResolved    Dispute[]        @relation("DisputesResolved")
  disputeMessages     DisputeMessage[] @relation("DisputeMessages")
  // T-059 admin moderation — videos this admin hid.
  videosHidden        ListingVideo[]   @relation("ListingVideosHidden")
  // TRU-09 — admin audit trail rows authored by this user.
  auditLogs           AuditLog[]       @relation("AdminAuditLogs")
  // ADM-08 — admin notes authored by this admin.
  adminNotes          AdminNote[]      @relation("AdminNotesAuthored")
  // PAY-09 — payments this admin has marked REFUNDED.
  refundedPayments    Payment[]        @relation("PaymentRefundedBy")
  // TRU-11 — blocklist entries created by this admin.
  blocklistEntries    BlocklistEntry[] @relation("BlocklistCreatedBy")
  // OWN-12 — web push subscriptions attached to this user.
  pushSubscriptions   PushSubscription[]

  @@index([status, role])
}

/**
 * Ticket from the Expo Push API. Persisted between send + receipt-
 * poll (~15-30 min gap) so the cron at /api/cron/push-receipts can
 * look up the original recipient when a `DeviceNotRegistered`
 * receipt comes back and clear the stale token from User.
 * Delete-on-poll : no `polledAt` column, the cron drops the row
 * once it's handled (success or terminal error).
 */
model PushReceipt {
  id       String   @id @default(cuid())
  // Expo's receipt id (one per recipient per send). UNIQUE because
  // Expo guarantees uniqueness across all customers.
  ticketId String   @unique
  userId   String
  sentAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The cron filter is `sentAt < now() - 15min` — index makes that scan O(log n).
  @@index([sentAt])
}

/**
 * Single-use TOTP recovery codes. Hashed (bcrypt) so a DB dump can't
 * harvest plaintext codes. `usedAt` flags consumed codes.
 */
model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

enum UserRole {
  STUDENT
  OWNER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum Locale {
  FR_MG
  MG
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// T-002 — Phone OTP (2026-06-11)
//
// Anonymous-friendly verification gate for the public lead form
// (E-T28 T-RES-05). The flow :
//   1. Visitor enters phone in the lead dialog.
//   2. Action calls `requestPhoneOtp(phoneE164)` which generates a
//      6-digit code, bcrypt-hashes it, stores a PhoneOtp row, and
//      sends SMS via the provider abstraction (lib/sms/).
//   3. Visitor types the code into the dialog. Action calls
//      `verifyPhoneOtp(phoneE164, code)` which sets `verifiedAt`.
//   4. `createInterestLead` checks for a recent verifiedAt row
//      (15 min window) before persisting the lead.
//
// Security :
//  - `phoneHash` only (peppered with AUTH_SECRET). Clear phone never
//    persisted on this table — the visitor proves possession by
//    typing the code, not by us storing the number.
//  - `codeHash` via bcrypt (work factor 10). One-shot — verified
//    rows can't be re-verified.
//  - `attempts` counter caps brute-force at 3 ; row marked
//    `consumedAt` on cap reached so the visitor has to request a
//    fresh code.
//  - `expiresAt` = createdAt + 10 min. Verify rejects expired.
//  - Cron sweep daily clears rows older than 24h (privacy).
// ============================================================
model PhoneOtp {
  id         String    @id @default(cuid())
  // SHA-256(phoneE164 + AUTH_SECRET) — never the raw phone.
  // Matches the `hashPhone` helper used by E-T28 rate-limit keys.
  phoneHash  String
  // bcrypt(code, 10). One-way.
  codeHash   String
  // Set ONCE on successful verify. Used by downstream consumers
  // (createInterestLead) to gate writes.
  verifiedAt DateTime?
  // Brute-force counter — reset to 0 on a fresh request, capped at 3.
  attempts   Int       @default(0)
  // Marked when attempts reach the cap OR when the row was already
  // consumed by a downstream use-case. Either way, can't be re-used.
  consumedAt DateTime?
  // createdAt + 10 min. Verify rejects past this.
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  // Hot path: a verify lookup is `WHERE phoneHash = ? AND
  // verifiedAt IS NULL AND consumedAt IS NULL AND expiresAt > now()`.
  // Ordering by createdAt DESC to get the latest unconsumed row.
  @@index([phoneHash, createdAt])
  // Cron sweep filter : `WHERE createdAt < now() - 24h`.
  @@index([createdAt])
}

// ============================================================
// LOGIN EVENTS — audit trail per user, shown in /dashboard/settings
// ============================================================

model LoginEvent {
  id          String          @id @default(cuid())
  userId      String
  occurredAt  DateTime        @default(now())
  authMethod  LoginAuthMethod
  ipHash      String? // SHA-256(ip + AUTH_SECRET), no raw IP
  userAgent   String?         @db.Text
  browser     String? // "Chrome"
  os          String? // "Windows"
  deviceType  String? // "desktop" | "mobile" | "tablet"
  isMobileApp Boolean         @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt(sort: Desc)])
}

enum LoginAuthMethod {
  CREDENTIALS
  GOOGLE
  FACEBOOK
  MAGIC_LINK
  MOBILE_JWT
}

// ============================================================
// OWNER PROFILE — v0.5 (owner verification, encrypted CIN)
// ============================================================

model OwnerProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique
  // CIN (national ID) — encrypted at rest with AES-256-GCM, key derived
  // from `env.PII_ENCRYPTION_KEY`. NEVER decrypt outside the admin
  // verification flow. The DB rows are useless without the env key.
  cinCiphertext      Bytes?
  cinIv              Bytes?
  cinAuthTag         Bytes?
  // Key version — bumped on rotation so old ciphertext can be decrypted
  // with the previous key while new uploads use the current one.
  cinKeyVersion      Int       @default(1)
  // Stored alongside the ciphertext so the admin viewer can serve the
  // right Content-Type when displaying the decrypted image.
  cinMimeType        String?
  cinUploadedAt      DateTime?
  // TRU-02 — selfie captured alongside the CIN. Same AES-256-GCM
  // encryption pipeline; same key version scheme so rotations cover
  // both. Nullable so historical rows (CIN only) stay valid.
  selfieCiphertext   Bytes?
  selfieIv           Bytes?
  selfieAuthTag      Bytes?
  selfieKeyVersion   Int?
  selfieMimeType     String?
  selfieUploadedAt   DateTime?
  // Admin verification outcome (T-039). `verifiedAt` is set on approve;
  // `cinRejectionReason` is set on reject (user-facing message). The two
  // are mutually exclusive — an admin re-review clears the previous
  // outcome before writing the new one.
  verifiedAt         DateTime?
  verifiedBy         String? // admin userId who approved
  cinRejectionReason String?   @db.Text
  cinRejectedAt      DateTime?
  cinRejectedBy      String? // admin userId who rejected
  // Admin-internal annotations — not shown to the owner.
  notes              String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// GEO — v0
// ============================================================

model City {
  id        String   @id @default(cuid())
  slug      String   @unique // "fianarantsoa"
  nameFr    String
  nameMg    String
  lat       Decimal  @db.Decimal(9, 6)
  lng       Decimal  @db.Decimal(9, 6)
  createdAt DateTime @default(now())

  neighborhoods   Neighborhood[]
  listings        Listing[]
  preferringUsers User[] // E-T07 inverse for User.preferredCity
  universities    University[] // TEN-11
}

model Neighborhood {
  id        String   @id @default(cuid())
  cityId    String
  slug      String // "andrainjato"
  nameFr    String
  nameMg    String
  lat       Decimal  @db.Decimal(9, 6)
  lng       Decimal  @db.Decimal(9, 6)
  createdAt DateTime @default(now())

  // E-T07 Batch A — editorial copy (tagline / landmark / ambiance / walk
  // / transport / distance) keyed by locale. Hydrated from the seed
  // helpers via migration 20260526210000. Consumers (landing,
  // /villes/[slug]/quartiers/[slug]) still read from the TS module in
  // Batch A; refactor to read from this column comes in Batch B.
  // Shape: { fr: { tagline, landmark, ambiance, walk, transport, distance }, mg: {...} }
  editorial Json?

  // E-T07 Batch A — quiz scoring profile (priceTier / schoolScores /
  // housingMix / vibe / mobilityScores / strengths). Same hydrate
  // strategy. Zod-validated at write time once Batch C admin UI ships
  // so an admin can't smuggle invalid values into the ranking algo.
  quizProfile Json?

  city         City                     @relation(fields: [cityId], references: [id], onDelete: Restrict)
  listings     Listing[]
  universities NeighborhoodUniversity[]

  @@unique([cityId, slug])
  @@index([cityId])
}



// ============================================================
// LISTINGS — v0 (core)
// ============================================================

model Listing {
  id             String @id @default(cuid())
  ownerId        String
  cityId         String
  neighborhoodId String

  title           String
  slug            String // SEO slug, computed from title + suffix of id
  description     String      @db.Text
  type            ListingType
  // Ariary has no subunit (the iraimbilanja is defunct). Integer storage
  // saves bytes, avoids Decimal/string interop bugs in JS, and matches
  // the Zod schema that already validates the input as a positive int.
  priceMonthlyMGA Int
  // E-T26 — caution policy declared at listing time. Stored as a
  // multiplier on `priceMonthlyMGA`. Standard Madagascar housing
  // practice : 0.5-3 months. The caution amount (in Ariary) is
  // derived at lease-signing time = priceMonthlyMGA × cautionMonths,
  // rounded — MGA has no subunit. Set to 0 if no caution is required.
  // Float (not Int) since 2026-06-12 to support a half-month option.
  cautionMonths   Float       @default(2)
  surfaceM2       Int?
  bedrooms        Int?
  bathrooms       Int?
  furnished       Boolean     @default(false)
  // Amenities — Postgres enum array, defaults to empty so existing rows
  // stay valid without a backfill.
  amenities       Amenity[]   @default([])
  // Owner-defined amenities (free-form labels). Each entry max 60 chars
  // — validated at the schema layer. Use sparingly: well-known equipment
  // belongs in the `Amenity` enum so it benefits from i18n + icons.
  customAmenities String[]    @default([])

  // geo (optional — falls back to neighborhood centroid)
  lat Decimal? @db.Decimal(9, 6)
  lng Decimal? @db.Decimal(9, 6)

  status      ListingStatus @default(DRAFT)
  publishedAt DateTime?

  // admin moderation (when suspended)
  suspendedReason String?
  suspendedAt     DateTime?
  suspendedBy     String?

  // OWN-20 — reason captured when the owner flips PUBLISHED → UNAVAILABLE.
  // Nullable so historical UNAVAILABLE rows stay valid. Cleared when the
  // owner re-publishes (UNAVAILABLE → PUBLISHED) so the next churn has
  // a fresh reason to capture.
  unavailableReason   UnavailableReason?
  unavailableReasonAt DateTime?

  // admin trust marker — set by an admin via verifyListing(). Powers the
  // "Annonce vérifiée" badge on the public card + detail. Cleared by
  // unverifyListing(). `verifiedBy` is a soft FK (admin user id) kept
  // even after re-verification cycles for audit, not modelled as a
  // hard relation to survive admin deletion gracefully.
  verifiedAt DateTime?
  verifiedBy String?

  // T-049 — auto-expiration lifecycle. Set on first publish to
  // (publishedAt + 60d) so abandoned listings don't pollute the
  // catalog forever. The daily cron flips PUBLISHED → UNAVAILABLE
  // when this date passes and emails the owner so they can extend
  // with a single click. NULL while the listing is still DRAFT.
  expiresAt             DateTime?
  // Set when the 7-day-warning email has been delivered so the cron
  // doesn't re-spam an owner who already got the notice. Cleared when
  // the owner extends — they get a fresh warning at the next cycle.
  expirationAlertSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  city          City           @relation(fields: [cityId], references: [id], onDelete: Restrict)
  neighborhood  Neighborhood   @relation(fields: [neighborhoodId], references: [id], onDelete: Restrict)
  photos        ListingPhoto[]
  contactEvents ContactEvent[]
  reports       Report[]
  reviews       Review[]
  favorites     Favorite[]
  payments      Payment[]
  leases        Lease[]
  // E-T28 — concierge lead queue. Multiple concurrent leads allowed per
  // listing by design (operator arbitrates which one converts).
  leadRequests  LeadRequest[]
  // T-058 — listing-view tracking for owner analytics (2026-06-25).
  // One row per unique visitor per 30 min window (dedup app-side).
  views         ListingView[]
  // T-059 — single optional walkthrough video. Surfaced as a click-
  // to-play overlay on the photo gallery.
  video         ListingVideo?

  // Slug is unique PER neighborhood (matches the URL path
  // /[city]/[neighborhood]/[slug]) so the same slug can recur across
  // different neighborhoods without forcing ugly suffixes.
  @@unique([neighborhoodId, slug])
  @@index([status, cityId, neighborhoodId])
  @@index([status, publishedAt(sort: Desc)])
  @@index([status, priceMonthlyMGA])
  @@index([ownerId, status])
  // Covers public list queries that filter by quartier + status and sort
  // by recency — `/annonces?neighborhood=X` + the per-quartier rail on
  // the landing. The composite (status, cityId, neighborhoodId) above
  // doesn't cover the sort, forcing a heap re-sort on every page.
  @@index([status, neighborhoodId, publishedAt(sort: Desc)])
  // `Listing.amenities` `hasEvery` filter on the public list page does
  // an array containment scan — GIN turns it from O(rows) into O(log n).
  @@index([amenities], type: Gin)
  // T-049 daily cron : find PUBLISHED listings approaching or past
  // their expiration date. Composite covers both the 7d-warning and
  // the auto-expire queries.
  @@index([status, expiresAt])
  // 2026-06-09 sidebar filters (bedrooms / bathrooms / furnished / type).
  // Composite (status, X) lets the planner index-scan instead of
  // seq-scanning all PUBLISHED rows. Audit fix 2026-06-12.
  @@index([status, type])
  @@index([status, bedrooms])
  @@index([status, bathrooms])
  @@index([status, furnished])
}

enum ListingType {
  ROOM
  STUDIO
  APARTMENT
  HOUSE
}

// Amenities offered by a listing — fixed catalog v0; admin can request
// additions as new student needs come up. Values are stable identifiers
// (i18n labels + icons live in code), so renaming a label here is safe.
enum Amenity {
  WIFI // Internet WiFi inclus
  PARKING // Parking voiture
  MOTO_PARKING // Parking moto / vélo
  HOT_WATER // Eau chaude
  WATER_TANK // Citerne / réserve d'eau
  GENERATOR // Groupe électrogène
  AIR_CONDITIONING // Climatisation
  KITCHEN_EQUIPPED // Cuisine équipée (frigo, gazinière)
  WASHING_MACHINE // Machine à laver
  GUARD // Gardiennage 24/7
  SECURITY_GATE // Portail fermé / clôture
  TERRACE // Terrasse / balcon
  GARDEN // Jardin
  STUDY_DESK // Bureau / coin étude
  CLOSE_TO_UNIVERSITY // Proche université
  CLOSE_TO_MARKET // Proche marché
  PUBLIC_TRANSPORT // Transport en commun proche
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  UNAVAILABLE
  SUSPENDED
  DELETED
  RENTED // E-T26 — bail actif sur la plateforme, masqué de la grille publique
}

// OWN-20 — reason surfaced when the owner marks a listing UNAVAILABLE.
// Kept short + closed so the ops team can slice metrics ("how many
// PUBLISHED listings actually converted vs churned off-platform").
enum UnavailableReason {
  RENTED_VIA_ARYTRANO // Loué via une demande AryTrano
  RENTED_OFF_PLATFORM // Loué en dehors d'AryTrano
  TAKING_A_BREAK // Pause temporaire (chantier, vacances…)
  OTHER
}

model ListingPhoto {
  id           String   @id @default(cuid())
  listingId    String
  url          String // Cloudinary delivery URL
  cloudinaryId String // Cloudinary public ID (for deletion / transforms)
  width        Int
  height       Int
  blurhash     String?
  altFr        String?
  altMg        String?
  position     Int      @default(0)
  createdAt    DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, position])
  @@index([listingId])
}

// T-059 — Listing visit walkthrough video (2026-06-25)
//
// One short walkthrough video per listing (v1 — single video). The
// owner uploads from the listing edit page ; the detail page shows a
// click-to-play poster overlay on the photo gallery so the heavy
// stream NEVER auto-loads on 3G.
//
// Cloudinary handles transcoding (HLS + MP4) + an auto-generated
// poster JPG via the `so_2` derivation (frame at 2s). We store the
// delivery URL + posterUrl so the player gets a thumbnail with
// blurhash before the metadata fetches.
model ListingVideo {
  id            String              @id @default(cuid())
  listingId     String              @unique // 1 video per listing in v1
  url           String // Cloudinary delivery URL (.mp4 or HLS .m3u8)
  cloudinaryId  String // public_id for deletion + transforms
  posterUrl     String // auto-generated JPG poster (so_2)
  posterBlurhash String?
  // Duration in seconds — capped to 120s at upload time to keep
  // bandwidth bounded ("brief walkthrough" not "full tour").
  durationSec   Int
  // Bytes of the original upload — drives the dashboard's quota
  // display.
  bytes         Int
  // T-059 moderation (2026-06-25) — admin can flip to HIDDEN_BY_ADMIN
  // to suppress public surfacing without dropping the asset (so the
  // owner can be notified + appeal). Public queries filter on this.
  status        ListingVideoStatus  @default(PUBLISHED)
  // Admin who hid the video + when + why. NULL when PUBLISHED.
  hiddenById    String?
  hiddenAt      DateTime?
  hiddenReason  String?
  createdAt     DateTime            @default(now())

  listing  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  hiddenBy User?   @relation("ListingVideosHidden", fields: [hiddenById], references: [id], onDelete: SetNull)

  // Hot path : public queries filter `status=PUBLISHED` ; admin queue
  // wants the moderation oldest-first.
  @@index([status, createdAt])
}

enum ListingVideoStatus {
  PUBLISHED
  HIDDEN_BY_ADMIN
}

// T-058 — Listing visit tracking (2026-06-25)
//
// One row per listing detail page view, written via `after()` from
// the public detail RSC so the response isn't blocked. Used by the
// owner dashboard "Stats" widget to surface views over time + the
// admin moderation queue to spot abuse spikes.
//
// PRIVACY : viewerHash is SHA-256(ipHash + AUTH_SECRET), so neither
// the raw IP nor any cookie value is stored. Same anonymisation
// pattern as ContactEvent / LoginEvent.
//
// DEDUP : the service drops a write if the same viewerHash hit the
// same listing within 30 minutes — implemented in `recordListingView`
// via a `findFirst` before insert. This keeps the table from inflating
// on bot scrapes + tab refreshes.
model ListingView {
  id          String   @id @default(cuid())
  listingId   String
  // Hashed visitor identifier (IP + pepper). Null when the request
  // arrived without a routable IP (CF cold edge, internal cron, etc.).
  viewerHash  String?
  // Hashed session id (cookie or `Auth.js` session id) — collapses
  // multiple IPs from the same logged-in user into one row over the
  // 30-min dedup window.
  sessionHash String?
  // Coarse source classification : 'direct' (no referer), 'internal'
  // (referer matches AUTH_URL host), 'search' (Google etc.),
  // 'social' (wa.me, facebook…), 'other'.
  source      String
  // Authenticated viewer userId — null for anonymous traffic. Used so
  // the dashboard can show "X of your views were from signed-in users".
  viewerUserId String?
  createdAt   DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // Hot path : owner dashboard `WHERE listingId=? AND createdAt > now()-7d`.
  // Covers cron sweeps and the per-listing "last 30d" trend.
  @@index([listingId, createdAt(sort: Desc)])
  // Anti-abuse : "this hash hit N listings in the last hour".
  @@index([viewerHash, createdAt])
}

// ============================================================
// CONTACT — v0 (basic analytics, no PII)
// ============================================================

model ContactEvent {
  id                 String         @id @default(cuid())
  listingId          String
  // Signed-in viewer's userId when known. Null for anonymous reveals.
  // Powers `Review.verifiedStay` (T-031) — a review is "verified" when
  // its author has at least one prior ContactEvent on the listing.
  // SetNull on user delete so the event row survives account anonymisation.
  viewerId           String?
  channel            ContactChannel
  ipHash             String // SHA-256(ip + secret), no raw IP
  uaHash             String? // SHA-256(user agent + secret)
  createdAt          DateTime       @default(now())
  // Set when the prompt-review cron has emailed the viewer to ask
  // for a review. Prevents the cron from re-emailing the same
  // viewer for the same listing every day. Null = never prompted.
  reviewPromptSentAt DateTime?

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  viewer  User?   @relation(fields: [viewerId], references: [id], onDelete: SetNull)

  @@index([listingId, createdAt])
  @@index([listingId, viewerId])
  // Used by the daily prompt-review cron to find candidates fast.
  @@index([reviewPromptSentAt, createdAt])
}

enum ContactChannel {
  WHATSAPP
  PHONE
}

// ============================================================
// REPORTS — v0 (signalements)
