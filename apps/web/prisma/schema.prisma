model Report {
  id         String       @id @default(cuid())
  listingId  String
  reporterId String? // null = anonymous (rate-limited by IP server-side)
  reason     ReportReason
  details    String?      @db.Text // free text from the reporter
  status     ReportStatus @default(OPEN)
  /// Visible to the reporter (email) + the listing owner (dashboard).
  /// Captured when admin resolves / dismisses — explains the decision.
  /// NOT for internal-only notes.
  adminNote  String?      @db.Text
  resolvedAt DateTime?
  resolvedBy String? // admin userId
  createdAt  DateTime     @default(now())

  listing  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporter User?   @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([listingId])
}

enum ReportReason {
  SCAM
  STOLEN_PHOTOS
  WRONG_INFO
  INAPPROPRIATE
  ALREADY_RENTED
  OTHER
}

enum ReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

// ============================================================
// REVIEWS — v0.5 (stub — not wired up in v0)
// ============================================================

model Review {
  id            String       @id @default(cuid())
  listingId     String
  authorId      String
  rating        Int // 1..5 (validated server-side)
  body          String       @db.Text
  verifiedStay  Boolean      @default(false) // set true if linked to a verified contact event / payment
  ownerResponse String?      @db.Text
  status        ReviewStatus @default(PUBLISHED)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  listing   Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions ReviewReaction[]

  @@unique([listingId, authorId])
  @@index([listingId, status, createdAt(sort: Desc)])
}

enum ReviewStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

// Single-reaction-per-user model: LIKE or DISLIKE, never both. The PK
// `(reviewId, userId)` enforces uniqueness; updating the row flips kind.
model ReviewReaction {
  reviewId  String
  userId    String
  kind      ReactionKind
  createdAt DateTime     @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([reviewId, userId])
  @@index([reviewId, kind])
  @@index([userId])
