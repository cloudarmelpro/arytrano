# ============================================================
# AryTrano — Local dev env template
# Copy to .env and fill values. .env is gitignored.
# ============================================================

# --- Database (matches docker-compose.yml) -------------------
DATABASE_URL="postgresql://arytrano:arytrano_dev@localhost:5432/arytrano?schema=public"

# --- Auth.js (web sessions) + JWT (mobile) -------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# --- Google OAuth (optional, enables Sign in with Google) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 client ID
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Facebook OAuth (optional, enables Sign in with Facebook)
# developers.facebook.com → My Apps → Create App → Facebook Login
# Redirect URI: <AUTH_URL>/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# --- Email via Gmail SMTP ------------------------------------
# Requires 2FA + App Password from https://myaccount.google.com/apppasswords
# Free tier ~100 emails/day. For prod, swap to Resend / SES / Postmark.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
EMAIL_FROM="AryTrano <user@example.com>"

# --- Cloudinary (image hosting) ------------------------------
# Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Upload preset created in Cloudinary settings → Upload presets (unsigned mode)
CLOUDINARY_UPLOAD_PRESET=""

# --- GoalPay (v2 — payments) ---------------------------------
# Merchant API key (starts with TGP_) — sent by GoalPay support after
# merchant onboarding. NEVER exposed to the client. Required in prod.
GOALPAY_ACCESS_KEY=""
# HMAC-SHA256 shared secret (starts with SK_) for verifying inbound
# webhook signatures. Provided by GoalPay support alongside the access
# key. Same value must be set in the GoalPay merchant dashboard.
# Required in production.
GOALPAY_WEBHOOK_SECRET=""
# Full endpoint URL of the GoalPay initiate-payment API. No sandbox
# documented — testing in prod with minimal amounts (100 Ar). See
# public/docs/runbooks/payments-goalpay.md
PAYMENT_GOALPAY_URL="https://api.goalpay.pro/api/payement/service"

# --- Encryption (OwnerProfile.cinCiphertext, v0.5) -----------
# 32 bytes, base64. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PII_ENCRYPTION_KEY=""

# --- Upstash Redis (rate limiting) ---------------------------
# Create a free database at https://console.upstash.com/redis
# When both are set, rate limiters enforce: login 10/5min/IP, forgot-password
# 3/h/email + 10/h/IP, register 5/h/IP. When missing, fail-open with warning.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Backup freshness (T-055) --------------------------------
# Path the production backup script writes to. /api/health reads this
# file's mtime to report `lastBackupAgeHours`. Leave default in dev.
BACKUP_FRESHNESS_FILE="/var/lib/arytrano/last-backup.txt"

# --- Sentry error tracking (T-056) ---------------------------
# All Sentry vars optional — no-op when DSN missing (zero dev overhead).
# Create a project at https://sentry.io/ → copy DSN + create an auth
# token (Settings > Account > API > Auth Tokens) for source map upload.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_ENVIRONMENT=""
SENTRY_TRACES_SAMPLE_RATE="0.1"

# --- Stadia Maps (AUD-008 — tiles) ---------------------------
# Required for production map tiles on /quartiers. Sign up at
# https://client.stadiamaps.com/signup (200k tile views/mo free).
# Restrict the key to your domains in the Stadia dashboard.
# When empty, the map falls back to public OSM apex (fine for dev).
NEXT_PUBLIC_STADIA_API_KEY=""
NEXT_PUBLIC_STADIA_STYLE="alidade_smooth"

# --- Cron secret (T-050 review prompt + others) --------------
# Shared Bearer token required by all /api/cron/* endpoints.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# In prod, set this in /etc/arytrano/app.env AND in the cron scheduler
# (Vercel Cron config or systemd timer) as the Authorization header.
CRON_SECRET=""
