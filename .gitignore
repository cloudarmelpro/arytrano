# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (any depth — apps/web/, apps/mobile/, packages/*/)
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js (any depth)
.next/
out/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python (ui-ux-pro-max skill cache)
__pycache__/
*.pyc

# claude code local settings (machine-specific)
.claude/settings.local.json

.vercel
