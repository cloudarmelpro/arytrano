# Don't fan npm run/test into workspaces by default. Workspaces are
# still RESOLVED (the @arytrano/shared file-link works), but commands
# like `npm test` and `npm run dev` continue to run the ROOT script
# the way they did before workspaces were introduced.
#
# To explicitly run a workspace script, use:
#   npm run typecheck -w @arytrano/shared
#
# To run a script across every workspace + root:
#   npm run X --workspaces --include-workspace-root --if-present
workspaces=false
